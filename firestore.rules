rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Each user can only touch their own sessions.
    match /users/{uid}/sessions/{sessionId} {
      allow read, write: if isOwner(uid);
    }

    // Daily-challenge attempts: three per day, per user, and an attempt
    // that has been recorded can be appended to but never shrunk — that
    // would hand back attempts the user has already spent.
    match /users/{uid}/challenges/{date} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.attempts.size() <= 3;
      allow update: if isOwner(uid)
                    && request.resource.data.attempts.size() <= 3
                    && request.resource.data.attempts.size() >= resource.data.attempts.size();
      allow delete: if false;
    }

    // Server-authoritative free-tier meter (users/{uid}/usage/{date}). The
    // paid analysis pipeline reserves an attempt here through the Admin SDK,
    // which bypasses these rules. The user may READ it (so the UI can show
    // attempts remaining) but must never write it — otherwise a free user
    // could zero out their own counter and mint unlimited analyses. Writes
    // are denied to everyone; only the Admin SDK, above the rules, sets it.
    match /users/{uid}/usage/{date} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Per-user profile docs (onboarding answers, XP/streak stats) — plus
    // `plan`, which is the entitlement itself and must stay read-only to
    // the user. Only the Stripe webhook writes it, via the Admin SDK,
    // which bypasses these rules. Otherwise anyone could PATCH their own
    // {plan: "premium"} and unlock every paid feature.
    //
    // The exclusion has to live HERE, in the wildcard, rather than in a
    // separate `match /users/{uid}/profile/plan { allow write: if false }`
    // block. Firestore ORs together every rule whose path matches, so a
    // narrower deny never overrides a broader allow — the wildcard would
    // simply grant the write anyway. (Verified: it did.)
    match /users/{uid}/profile/{docId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && docId != "plan";
    }

    // The speech of the day is shared by everybody. Any signed-in user may
    // publish the day that is missing, but nobody may rewrite or delete a
    // day that already exists — otherwise one user could swap the speech
    // out from under everyone mid-day, or wipe scores' comparability.
    match /dailyChallenges/{date} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Everything else is locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
